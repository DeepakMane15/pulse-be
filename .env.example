NODE_ENV=development
APP_NAME=video-platform-backend
API_PORT=4000
CLIENT_ORIGIN=http://localhost:5173

MONGO_URI=mongodb://localhost:27017/video_platform

RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_VIDEO_ANALYZE_QUEUE=video.analyze.queue
RABBITMQ_VIDEO_UPLOAD_QUEUE=video.upload.queue
RABBITMQ_VIDEO_EVENTS_QUEUE=video.lifecycle.events

# Rekognition video content moderation (video must be in S3 first — worker uses a staging prefix).
# IAM: rekognition:StartContentModeration, rekognition:GetContentModeration, s3:GetObject/PutObject/DeleteObject/CopyObject on the bucket.
REKOGNITION_ENABLED=true
REKOGNITION_MIN_CONFIDENCE=55
REKOGNITION_POLL_INTERVAL_MS=5000
REKOGNITION_MAX_WAIT_MS=900000

JWT_ACCESS_SECRET=change_this_access_secret

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
AWS_S3_BUCKET=replace_me

# Optional. Default: os temp dir + /pulse-video-uploads (works for local API + worker).
# Do NOT set to /var/pulse/uploads on your Mac/host unless that path exists and is writable — use Docker Compose for that path (see docker-compose.yml + docker-entrypoint.sh).
# VIDEO_UPLOAD_TMP_DIR=/path/you/can/write
